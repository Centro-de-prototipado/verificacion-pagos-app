# Copiar este archivo a .env.local y rellenar los valores.
# .env.local NO se sube a git (ver .gitignore).

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar con generateObject (multimodal, acepta PDF nativo)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar con Groq
GROQ_MODEL=llama-3.3-70b-versatile

# Mistral API key — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# Modelo a usar con Mistral
MISTRAL_MODEL=mistral-small-latest
